# OncoPipeline Intelligence — Environment Variables
# Copy this file to .env and fill in your values

# Groq API Key (get free at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Groq model to use (leave as default unless you know what you're changing)
GROQ_MODEL=llama-3.3-70b-versatile

# Cache TTL in seconds (how long to cache Groq responses)
GROQ_CACHE_TTL=600

# Data directory override (leave blank to use default ../Context/data/processed)
DATA_DIR=
